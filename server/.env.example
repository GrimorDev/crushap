# Copy to .env for local runs. In the Portainer stack these are set as
# stack environment variables instead (see docker-compose.yml).

PORT=3000
REDIS_URL=redis://redis:6379
JWT_SECRET=change-me-to-a-long-random-string
UPLOAD_DIR=/data/uploads
# Comma-separated list, or * for any origin (fine for a personal/dev deploy)
CORS_ORIGIN=*
